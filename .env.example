# Kiro-Go environment — copy this file to .env next to docker-compose.yml:
#   cp .env.example .env
# docker-compose tự đọc .env; file .env đã nằm trong .gitignore, đừng commit.

# Mật khẩu admin (BẮT BUỘC khi deploy công khai — app từ chối chạy với mật khẩu
# mặc định "changeme" trên host không phải loopback).
ADMIN_PASSWORD=

# Path bí mật của panel admin, ví dụ /panel-x7k9. Để trống = /admin mặc định.
# Khi đặt, đường dẫn /admin cũ trả 404 trơn như mọi route lạ.
ADMIN_PATH=

# Mức log: debug / info / warn / error. Để trống = theo config (mặc định info).
LOG_LEVEL=

# BẮT BUỘC khi app đứng sau reverse proxy (nginx) hoặc Cloudflare — xem
# DEPLOYMENT.md §5.2. Nếu không bật, rate limit per-IP tính mọi client chung
# một IP proxy; nếu bật mà không chặn traffic ngoài Cloudflare ở firewall thì
# client gọi thẳng IP gốc forge được X-Forwarded-For.
KIRO_TRUST_PROXY=

# Số proxy hop đứng trước app khi KIRO_TRUST_PROXY=true. Chỉ nginx: 1.
# Cloudflare → nginx → app: 2. Cloudflare trỏ thẳng app: 1. Mặc định: 1.
KIRO_TRUSTED_PROXY_HOPS=
