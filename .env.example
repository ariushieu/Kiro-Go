# Kiro-Go environment — copy this file to .env next to docker-compose.yml:
#   cp .env.example .env
# docker-compose tự đọc .env; file .env đã nằm trong .gitignore, đừng commit.

# Mật khẩu admin (BẮT BUỘC khi deploy công khai — app từ chối chạy với mật khẩu
# mặc định "changeme" trên host không phải loopback).
ADMIN_PASSWORD=

# Path bí mật của panel admin, ví dụ /panel-x7k9. Để trống = /admin mặc định.
# Khi đặt, đường dẫn /admin cũ trả 404 trơn như mọi route lạ.
ADMIN_PATH=

# Mức log: debug / info / warn / error. Để trống = theo config (mặc định info).
LOG_LEVEL=
